{
  "name": "flvm-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "velite && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "build-velite": "node ./lib/sveltia-to-velite.mjs",
    "velite": "velite --watch"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@skeletonlabs/skeleton": "^4.5.0",
    "@skeletonlabs/skeleton-svelte": "^4.5.0",
    "@sveltejs/adapter-vercel": "^6.3.2",
    "@sveltejs/kit": "^2.53.3",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^25.6.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.5",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@fontsource-variable/roboto": "^5.2.8",
    "@lucide/svelte": "^1.9.0",
    "velite": "^0.3.0"
  }
}
